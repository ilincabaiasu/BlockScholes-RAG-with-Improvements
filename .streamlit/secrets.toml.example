# Copy this file to .streamlit/secrets.toml for local use,
# OR paste each key into the Streamlit Cloud "Secrets" UI.
# .streamlit/secrets.toml is git-ignored — never commit real keys.

OPENAI_API_KEY   = "sk-..."        # required by config; not called when judge+generation are Gemini
GEMINI_API_KEY   = "AIza..."       # generation + (fallback) judge
COHERE_API_KEY   = "..."           # reranking
QDRANT_URL       = "https://your-cluster.qdrant.io"
QDRANT_API_KEY   = "..."
JUDGE_PROVIDER   = "gemini"        # "gemini" (works now) or "openai" (gpt-4o, unbiased — needs quota)

# Supabase — persistent shared Q&A history (All-time graph)
# Create a free project at supabase.com, then run this SQL in the Supabase SQL editor:
#
#   create table qa_runs (
#     id          bigint generated always as identity primary key,
#     created_at  timestamptz default now(),
#     batch_id    text, question text, pipeline text, enhanced_config text,
#     quality     real, retrieval_pct real, generation real,
#     factual_correctness real, grounding real, completeness real,
#     clarity real, usefulness real, latency_ms real, fail_flags integer
#   );
#
# Find SUPABASE_URL and SUPABASE_KEY (anon/public key) under Project Settings → API.
SUPABASE_URL     = "https://your-project.supabase.co"
SUPABASE_KEY     = "eyJ..."
